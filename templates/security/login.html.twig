{% extends 'auth_base.html.twig' %}

{% block robots %}index, follow{% endblock %}
{% block title %}Se connecter{% endblock %}
{% block description %}Connectez-vous pour accéder à des offres d'alternance dédiées aux étudiants. Trouvez l'opportunité idéale et lancez votre carrière. Inscription rapide et sécurisée.{% endblock %}
{% block url %}{{ path('app_login') }}{% endblock %}

{% block ogTitle %}Jaltup - Se connecter{% endblock %}
{% block ogUrl %}https://jaltup.com/connexion{% endblock %}
{% block ogImage %}{{ asset('image/jaltup-og.webp') }}{% endblock %}
{% block ogImageAlt %}Jaltup{% endblock %}
{% block ogDescription %}Connectez-vous pour accéder à des offres d'alternance dédiées aux étudiants. Trouvez l'opportunité idéale et lancez votre carrière. Inscription rapide et sécurisée.{% endblock %}

{% block body %}
    <section class="flex min-h-full flex-col justify-center py-12 sm:px-6 lg:px-8">
        <div class="sm:mx-auto sm:w-full sm:max-w-md">
            <a href="{{ path('app_offer') }}">
                <img class="mx-auto h-10 w-auto" src="{{ asset('logo/logo_min.svg') }}" alt="Jaltup Logo">
            </a>
            <h2 class="mt-6 text-center text-2xl font-bold leading-9 tracking-tight text-gray-900">Connexion à Jaltup</h2>
        </div>

        <div class="mt-10 sm:mx-auto sm:w-full sm:max-w-[480px]">
            <div class="bg-white px-6 py-12 border border-gray-300 sm:rounded-lg sm:px-12">
                <form class="space-y-6" action="#" method="POST">
                    {% if error %}
                        <div class="rounded-md bg-red-50 p-4">
                            <div class="flex">
                                <div class="flex-shrink-0">
                                    {{ ux_icon('gridicons:cross-circle', {class: 'h-5 w-5 text-red-400'}) }}
                                </div>
                                <div class="ml-3">
                                    <p class="text-sm font-medium text-red-800">{{ error.messageKey|trans(error.messageData, 'security') }}</p>
                                </div>
                            </div>
                        </div>
                    {% endif %}
                    <div>
                        <label for="email" class="block text-sm font-medium leading-6 text-gray-900">Adresse email</label>
                        <div class="mt-2">
                            <input id="email" value="{{ last_username }}" name="_username" type="email" autocomplete="email" required autofocus class="block w-full rounded-md border-0 py-1.5 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-gray-900 sm:text-sm sm:leading-6">
                        </div>
                    </div>

                    <div>
                        <label for="password" class="block text-sm font-medium leading-6 text-gray-900">Mot de passe</label>
                        <div class="mt-2">
                            <input id="password" name="_password" type="password" autocomplete="current-password" required class="block w-full rounded-md border-0 py-1.5 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-gray-900 sm:text-sm sm:leading-6">
                        </div>
                    </div>

                    <input type="hidden" name="_csrf_token"
                           value="{{ csrf_token('authenticate') }}"
                    >

                    <div class="flex items-center justify-between">
                        <div class="flex items-center">
                            <input name="_remember_me" id="_remember_me" type="checkbox" class="h-4 w-4 rounded border-gray-300 text-[#E68C12] focus:ring-[#E68C12]">
                            <label for="_remember_me" class="ml-3 block text-sm leading-6 text-gray-900">Rester identifié</label>
                        </div>

                        <div class="text-sm leading-6">
                            <a href="/reset-password" class="font-semibold text-gray-900 hover:text-gray-500">Mot de passe oublié ?</a>
                        </div>
                    </div>

                    <div>
                        <button type="submit" class="flex w-full border border-gray-900 justify-center rounded-full bg-gray-900 px-3.5 py-2.5 text-sm font-semibold leading-6 text-white shadow-sm hover:bg-transparent hover:text-gray-900">Se connecter</button>
                    </div>
                </form>
            </div>

            <p class="mt-10 text-center text-sm text-gray-500">
                Pas encore membre ?
                <a href="{{ path('app_register') }}" class="font-semibold leading-6 text-[#E68C12]">Créer un compte</a>
            </p>
        </div>
    </section>
{% endblock %}
