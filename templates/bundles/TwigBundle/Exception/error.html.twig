{% extends 'auth_base.html.twig' %}

{% block title %}Erreur{% endblock %}
{% block robots %}noindex, nofollow{% endblock %}

{% block body %}
    <main class="grid min-h-full place-items-center bg-white px-6 py-24 sm:py-32 lg:px-8">
    <div class="text-center">
        <p class="text-base font-semibold text-[#E68C12]">Erreur</p>
        <h1 class="mt-4 text-3xl font-bold tracking-tight text-gray-900 sm:text-5xl">Une erreur est survenue.</h1>
        <p class="mt-6 text-base leading-7 text-gray-600">Veuillez nous contactez pour corriger l'erreur.</p>
        <div class="mt-10 flex items-center justify-center gap-x-6">
            <a href="{{ path('app_offer') }}" class="rounded-full text-center bg-gray-900 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-transparent border border-gray-900 hover:text-gray-900 transition duration-100">Retourner aux offres</a>
            <a href="{{ path('app_contact') }}" class="text-sm font-semibold text-gray-900">Contactez-nous <span aria-hidden="true">&rarr;</span></a>
        </div>
    </div>
    </main>
{% endblock %}