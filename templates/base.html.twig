<!DOCTYPE html>
<html lang="fr">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">

        <title>Jaltup - {% block title %}{% endblock %}</title>

        {% block stylesheets %}
            {{ encore_entry_link_tags('app') }}
        {% endblock %}

        {% block javascripts %}
            {{ encore_entry_script_tags('app') }}
        {% endblock %}
    </head>
    <body>
        <header class="max-w-6xl mx-auto absolute inset-x-0 top-0 z-50">
            <nav class="flex items-center justify-between p-6 lg:px-8" aria-label="Global">
                <div class="flex lg:flex-1">
                    <a href="{{ path('app_offer') }}" class="-m-1.5 p-1.5">
                        <span class="sr-only">Jaltup</span>
                        <img class="h-8 md:h-10 w-auto" src="{{ asset('logo/logo.png') }}" alt="Logo Jaltup">
                    </a>
                </div>
                <div class="flex flex-1 justify-end">
                    <a href="{{ path('app_register')}}" type="button" class="rounded-full border border-white px-3 py-2 text-sm font-semibold text-white hover:bg-white hover:text-gray-900 transition duration-100">S'inscrire</a>
                </div>
            </nav>
        </header>
        <main>
            {% block body %}{% endblock %}
        </main>
        <footer>

        </footer>
    </body>
</html>
