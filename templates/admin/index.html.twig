{% extends 'base.html.twig' %}

{% block robots %}noindex, nofollow{% endblock %}
{% block title %}Admin{% endblock %}
{% block url %}{{ path('app_admin') }}{% endblock %}

{% block body %}
    Nombre d'inscrit : {{ users|length }}<br/><br/>
    {% for user in users %}
        {{ user.id }}
        <br/>{{ user.firstName }} . {{ user.lastName }}
        <br/>{{ user.email }}
        <br/>{{ user.createdAt|date('d/m/Y') }}
        <br/><br/>
    {% endfor %}
{% endblock %}
