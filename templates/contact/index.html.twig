{% extends 'base.html.twig' %}

{% block robots %}index, follow{% endblock %}
{% block title %}Contact{% endblock %}
{% block description %}Contactez notre équipe pour toute question sur les offres d'alternance. Nous sommes là pour aider les étudiants à trouver des opportunités adaptées. Réponse rapide assurée.{% endblock %}
{% block url %}{{ path('app_contact') }}{% endblock %}

{% block ogTitle %}Jaltup - Contact{% endblock %}
{% block ogUrl %}https://jaltup.com/contact{% endblock %}
{% block ogImage %}{{ asset('image/jaltup-og.webp') }}{% endblock %}
{% block ogImageAlt %}Jaltup{% endblock %}
{% block ogDescription %}Contactez notre équipe pour toute question sur les offres d'alternance. Nous sommes là pour aider les étudiants à trouver des opportunités adaptées. Réponse rapide assurée.{% endblock %}

{% block body %}
    <section class="isolate bg-gray-900 px-6 py-24 sm:py-32 lg:px-8 z-50">
        <div class="absolute inset-x-0 top-[-10rem] -z-10 transform-gpu overflow-hidden blur-3xl sm:top-[-20rem]" aria-hidden="true">
            <div class="relative left-1/2 -z-10 aspect-[1155/678] w-[36.125rem] max-w-none -translate-x-1/2 rotate-[30deg] bg-gradient-to-tr from-[#ff80b5] to-[#9089fc] opacity-30 sm:left-[calc(50%-40rem)] sm:w-[72.1875rem]" style="clip-path: polygon(74.1% 44.1%, 100% 61.6%, 97.5% 26.9%, 85.5% 0.1%, 80.7% 2%, 72.5% 32.5%, 60.2% 62.4%, 52.4% 68.1%, 47.5% 58.3%, 45.2% 34.5%, 27.5% 76.7%, 0.1% 64.9%, 17.9% 100%, 27.6% 76.8%, 76.1% 97.7%, 74.1% 44.1%)"></div>
        </div>
        <div class="mx-auto max-w-2xl text-center mt-5">
            <h2 class="text-4xl font-bold tracking-tight text-white sm:text-6xl">Contactez-nous</h2>
            <p class="mt-6 text-lg leading-8 text-gray-300">Pour toute question ou demande, remplissez le formulaire ci-dessous. <br/>Nous vous répondrons sous 24h maximum.</p>
        </div>
    </section>

    <section class="isolate bg-white px-6 py-20 lg:px-8">
        {{ form_start(form, {'attr': {'class': 'mx-auto max-w-xl'}}) }}
            {% for message in app.flashes('success') %}
                <div class="rounded-md bg-green-50 p-4 mb-10">
                    <div class="flex">
                        <div class="flex-shrink-0">
                            <svg class="h-5 w-5 text-green-400" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" />
                            </svg>
                        </div>
                        <div class="ml-3">
                            <p class="text-sm font-medium text-green-800">{{ message }}</p>
                        </div>
                    </div>
                </div>
            {% endfor %}
            <div class="grid grid-cols-1 gap-x-8 gap-y-6 sm:grid-cols-2">
                <div>
                    <label class="block text-sm font-semibold leading-6 text-gray-900">{{ form_label(form.fullName, 'Nom complet') }}</label>
                    <div class="mt-2.5">
                        {{ form_widget(form.fullName, {
                            'attr': {
                                'class': 'capitalize block w-full rounded-md border-0 px-3.5 py-2 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-gray-900 sm:text-sm sm:leading-6',
                                'value': app.user ? (app.user.firstName ~ ' ' ~ app.user.lastName) : ''
                            }
                        }) }}
                    </div>
                    <div class="text-red-600 text-sm mt-1">
                        <p>{{ form_errors(form.fullName) }}</p>
                    </div>
                </div>
                <div>
                    <div class="flex justify-between">
                        <label class="block text-sm font-semibold leading-6 text-gray-900">{{ form_label(form.phoneNumber, 'Téléphone') }}</label>
                        <span class="text-sm leading-6 text-gray-500" id="email-optional">Optionnel</span>
                    </div>
                    <div class="mt-2.5">
                        {{ form_widget(form.phoneNumber, {'attr': {'class':'block w-full rounded-md border-0 px-3.5 py-2 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-gray-900 sm:text-sm sm:leading-6'}}) }}
                    </div>
                    <div class="text-red-600 text-sm mt-1">
                        <p>{{ form_errors(form.phoneNumber) }}</p>
                    </div>
                </div>
                <div class="sm:col-span-2">
                    <label class="block text-sm font-semibold leading-6 text-gray-900">{{ form_label(form.email, 'Adresse e-mail') }}</label>
                    <div class="mt-2.5">
                        {{ form_widget(form.email, {
                            'attr': {
                                'class': 'block w-full rounded-md border-0 px-3.5 py-2 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-gray-900 sm:text-sm sm:leading-6',
                                'value': app.user ? (app.user.email) : ''
                            }
                        }) }}
                    </div>
                    <div class="text-red-600 text-sm mt-1">
                        <p>{{ form_errors(form.email) }}</p>
                    </div>
                </div>
                <div class="sm:col-span-2">
                    <div class="flex justify-between">
                        <label class="block text-sm font-semibold leading-6 text-gray-900">{{ form_label(form.society, 'Société ou école') }}</label>
                        <span class="text-sm leading-6 text-gray-500" id="email-optional">Optionnel</span>
                    </div>
                    <div class="mt-2.5">
                        {{ form_widget(form.society, {'attr': {'class':'block w-full rounded-md border-0 px-3.5 py-2 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-gray-900 sm:text-sm sm:leading-6'}}) }}
                    </div>
                    <div class="text-red-600 text-sm mt-1">
                        <p>{{ form_errors(form.society) }}</p>
                    </div>
                </div>
                <div class="sm:col-span-2">
                    <label class="block text-sm font-semibold leading-6 text-gray-900">{{ form_label(form.subject, 'Sujet') }}</label>
                    <div class="mt-2.5">
                        {{ form_widget(form.subject, {'attr': {'class':'block w-full rounded-md border-0 px-3.5 py-2 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-gray-900 sm:text-sm sm:leading-6'}}) }}
                    </div>
                    <div class="text-red-600 text-sm mt-1">
                        <p>{{ form_errors(form.subject) }}</p>
                    </div>
                </div>
                <div class="sm:col-span-2">
                    <div class="flex justify-between">
                        <label class="block text-sm font-semibold leading-6 text-gray-900">{{ form_label(form.message, 'Message') }}</label>
                        <span class="text-sm leading-6 text-gray-500" id="email-optional">Optionnel</span>
                    </div>
                    <div class="mt-2.5">
                        {{ form_widget(form.message, {'attr': {'class':' w-full rounded-md border-0 px-3.5 py-2 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-gray-900 sm:text-sm sm:leading-6', 'rows':'4'}}) }}
                    </div>
                    <div class="text-red-600 text-sm mt-1">
                        <p>{{ form_errors(form.message) }}</p>
                    </div>
                </div>
            </div>
            <div class="mt-10">
                <button type="submit" class="rounded-full bg-gray-900 px-3.5 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-transparent border border-gray-900 hover:text-gray-900 transition duration-100 block w-full">Envoyer</button>
            </div>
        {{ form_end(form) }}
    </section>
{% endblock %}
